generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  image     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model Credit {
  email      String   @id
  credits    Int      @default(5)
  totalUsed  Int      @default(0) @map("total_used")
  plan       String   @default("free")
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("credits")
}

model Analysis {
  id              String   @id @default(uuid())
  userEmail       String?  @map("user_email")
  contractSnippet String?  @map("contract_snippet")
  overallScore    Int?     @map("overall_score")
  recommendation  String?
  nominalRate     Float?   @map("nominal_rate")
  effectiveRate   Float?   @map("effective_rate")
  rateReduction   Float?   @map("rate_reduction")
  currency        String   @default("USD")
  contractType    String?  @map("contract_type")
  fullResult      Json?    @map("full_result")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userEmail])
  @@index([createdAt(sort: Desc)])
  @@map("analyses")
}

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("admin_settings")
}

model ContractVersion {
  id            String   @id @default(uuid())
  userEmail     String?  @map("user_email")
  contractName  String?  @map("contract_name")
  versionNumber Int      @default(1) @map("version_number")
  analysisId    String?  @map("analysis_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("contract_versions")
}

model Payment {
  id                String   @id @default(uuid())
  email             String
  razorpayOrderId   String   @map("razorpay_order_id")
  razorpayPaymentId String   @map("razorpay_payment_id")
  planId            String   @map("plan_id")
  amount            Int
  currency          String   @default("USD")
  creditsAdded      Int      @map("credits_added")
  status            String
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([razorpayOrderId])
  @@map("payments")
}

model BlogPost {
  id              String    @id @default(uuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  authorEmail     String    @map("author_email")
  authorName      String    @map("author_name")
  coverImageUrl   String?   @map("cover_image_url")
  tags            String[]  @default([])
  category        String    @default("general")
  isPublished     Boolean   @default(false) @map("is_published")
  isFeatured      Boolean   @default(false) @map("is_featured")
  seoTitle        String?   @map("seo_title")
  seoDescription  String?   @map("seo_description")
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  viewCount       Int       @default(0) @map("view_count")
  @@map("blog_posts")
}
